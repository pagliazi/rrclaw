# RRAgent Environment Variables
# Copy to .env and fill in your values.
# NEVER commit .env to git.

# ── LLM Providers ──
ANTHROPIC_API_KEY=
# Optional fallback providers:
# DASHSCOPE_API_KEY=
# OLLAMA_BASE_URL=http://127.0.0.1:11434

# ── OpenClaw Gateway ──
GATEWAY_URL=ws://127.0.0.1:18789
# GATEWAY_TOKEN=

# ── Redis ──
REDIS_URL=redis://127.0.0.1:6379/0
# With auth: redis://:yourpassword@127.0.0.1:6379/0

# ── ReachRich Market Data ──
# Bridge API endpoint
# Public: https://rr.zayl.net/api
# Local: http://192.168.1.138/api
REACHRICH_URL=https://rr.zayl.net/api
# User token for Bridge API + real-time data stream authentication.
# Get your API Key from ReachRich Settings → API Key (format: rk_...)
REACHRICH_TOKEN=
# Path to directory containing bridge_client.py
BRIDGE_CLIENT_PATH=

# ── Hermes Agent ──
HERMES_AGENT_PATH=
# HERMES_MODEL=claude-sonnet-4-6
# HERMES_PROVIDER=anthropic

# ── Model Override ──
# RRAgent_PRIMARY_MODEL=anthropic/claude-sonnet-4-6

# ── Session Storage ──
# RRAgent_SESSION_DIR=~/.rragent/sessions

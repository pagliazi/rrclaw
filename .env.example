# RRCLAW Environment Variables
# Copy to .env and fill in your values.
# NEVER commit .env to git.

# ── LLM Providers ──
ANTHROPIC_API_KEY=
# Optional fallback providers:
# DASHSCOPE_API_KEY=
# OLLAMA_BASE_URL=http://127.0.0.1:11434

# ── OpenClaw Gateway ──
GATEWAY_URL=ws://127.0.0.1:18789
# GATEWAY_TOKEN=

# ── Redis ──
REDIS_URL=redis://127.0.0.1:6379/0
# With auth: redis://:yourpassword@127.0.0.1:6379/0

# ── ReachRich Market Data ──
# Bridge API endpoint
# Example: http://192.168.1.x:8001/api/bridge
REACHRICH_URL=
# User token for Bridge API + real-time data stream authentication.
# Get your token from ReachRich: 设置 → API Token
# Format: {user_id}:{hmac_hex}
REACHRICH_TOKEN=
# Path to directory containing bridge_client.py
BRIDGE_CLIENT_PATH=

# ── Hermes Agent ──
HERMES_AGENT_PATH=
# HERMES_MODEL=claude-sonnet-4-6
# HERMES_PROVIDER=anthropic

# ── Model Override ──
# RRCLAW_PRIMARY_MODEL=anthropic/claude-sonnet-4-6

# ── Session Storage ──
# RRCLAW_SESSION_DIR=~/.rrclaw/sessions
